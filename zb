-- ========================================================================
-- SURVIVAL ZOMBIE SCRIPT EXPLOIT (MOBILE & PC COMPATIBLE V2.5)
-- Tối ưu hoàn toàn cho Executor trên Mobile (Delta, Fluxus, Codex, Arceus X) & PC
-- ========================================================================

local AUTO_KILL = true
local KILL_COOLDOWN = 0.05 -- Giãn cách 0.05s (20 lần/s) mượt mà không văng game trên Mobile
local DAMAGE_RADIUS = 9999 -- Diệt quái toàn map

local AUTO_COLLECT_SHARDS = true
local AUTO_COLLECT_RAIN = true
local AUTO_SKIP_WAVE = true -- Tự động Vote Skip Wave chuẩn bị

local UNDERGROUND_SAFE = true -- Bật chế độ chui xuống đất an toàn
local UNDERGROUND_DEPTH = 8 -- Độ sâu nấp dưới đất (studs)

-- Các biến hệ thống
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local function getHRP()
    return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
end

-- Hàm lấy Parent GUI an toàn trên mọi Executor Mobile & PC
local function getGuiParent()
    local success, gui = pcall(function()
        return (gethui and gethui()) or game:GetService("CoreGui")
    end)
    if success and typeof(gui) == "Instance" then
        return gui
    end
    return LocalPlayer:WaitForChild("PlayerGui", 10) or LocalPlayer.PlayerGui
end

-- Lấy ServiceRegistry an toàn
local ServiceRegistry = nil
pcall(function()
    local modules = ReplicatedStorage:FindFirstChild("Modules")
    if modules and modules:FindFirstChild("ServiceRegistry") then
        ServiceRegistry = require(modules.ServiceRegistry)
    end
end)

-- ========================================================================
-- ANTI-AFK SYSTEM (CHỐNG KICK VĂNG GAME KHỎI ROBLOX)
-- ========================================================================
pcall(function()
    local VirtualUser = game:GetService("VirtualUser")
    LocalPlayer.Idled:Connect(function()
        pcall(function()
            VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            task.wait(1)
            VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        end)
    end)

    task.spawn(function()
        while task.wait(300) do
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end)
        end
    end)
end)

-- ========================================================================
-- 1. HỆ THỐNG AN TOÀN CHUI XUỐNG ĐẤT (UNDERGROUND SAFE & NOCLIP)
-- ========================================================================
local groundCFrame = nil

LocalPlayer.CharacterAdded:Connect(function(char)
    groundCFrame = nil
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    task.wait(1)
    if hrp then
        groundCFrame = hrp.CFrame
    end
end)

RunService.Stepped:Connect(function()
    if not UNDERGROUND_SAFE then return end
    
    local character = LocalPlayer.Character
    local hrp = getHRP()
    
    if character and hrp then
        if not groundCFrame then
            groundCFrame = hrp.CFrame
        end
        
        local safeCFrame = groundCFrame * CFrame.new(0, -UNDERGROUND_DEPTH, 0)
        hrp.CFrame = safeCFrame
        hrp.Velocity = Vector3.zero
        hrp.RotVelocity = Vector3.zero
        
        for _, part in ipairs(character:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- ========================================================================
-- 2. AUTO KILL ALL ZOMBIES ON MAP (OPTIMIZED FOR MOBILE)
-- ========================================================================
task.spawn(function()
    print("[EXPLOIT] Khởi chạy Auto Kill Aura...")
    while task.wait(KILL_COOLDOWN) do
        if not AUTO_KILL then continue end
        
        local zombieClient = _G.ZombieClient
        local gunClient = _G.GunClient
        
        if ServiceRegistry then
            zombieClient = zombieClient or ServiceRegistry.Get("ZombieClient")
            gunClient = gunClient or ServiceRegistry.Get("GunClient")
        end
        
        local equippedGunName = "Pistol"
        local character = LocalPlayer.Character
        local tool = character and character:FindFirstChildWhichIsA("Tool")
        
        if tool then
            equippedGunName = tool.Name
        elseif gunClient and gunClient.EquippedGun then
            equippedGunName = gunClient.EquippedGun.Name
        end
        
        local hrp = getHRP()
        local zombieRemotes = ReplicatedStorage:FindFirstChild("ZombieRemotes")
        local gunRemotes = ReplicatedStorage:FindFirstChild("GunRemotes")
        local zombieDamageRemote = zombieRemotes and zombieRemotes:FindFirstChild("ZombieDamage")
        local gunHitRemote = gunRemotes and gunRemotes:FindFirstChild("GunHit")
        
        if hrp and zombieClient and zombieClient.Zombies then
            for id, zombie in pairs(zombieClient.Zombies) do
                if not zombie.IsDying and not zombie.IsMinion then
                    local zombiePos = zombie.CurrentPosition or (zombie.Model and zombie.Model.PrimaryPart and zombie.Model.PrimaryPart.Position) or hrp.Position
                    
                    pcall(function()
                        if zombieDamageRemote then
                            zombieDamageRemote:FireServer(id, 999999)
                        elseif gunHitRemote then
                            gunHitRemote:FireServer(equippedGunName, id, zombiePos)
                        end
                    end)
                end
            end
        end
    end
end)

-- ========================================================================
-- 3. AUTO COLLECT SHARDS (INSTANT REMOTE & TELEPORT)
-- ========================================================================
task.spawn(function()
    local eventRemotes = ReplicatedStorage:FindFirstChild("EventRemotes") or ReplicatedStorage:WaitForChild("EventRemotes", 5)
    if eventRemotes then
        local bloodmoonDrop = eventRemotes:FindFirstChild("BloodmoonShardDrop") or eventRemotes:FindFirstChild("GalacticShardDrop")
        local bloodmoonCollect = eventRemotes:FindFirstChild("BloodmoonShardCollect") or eventRemotes:FindFirstChild("GalacticShardCollect")
        
        if bloodmoonDrop and bloodmoonCollect then
            bloodmoonDrop.OnClientEvent:Connect(function(zombieId, count, pos)
                if AUTO_COLLECT_SHARDS then
                    pcall(function()
                        bloodmoonCollect:FireServer(zombieId)
                    end)
                end
            end)
        end
    end
    
    while task.wait(0.5) do
        local hrp = getHRP()
        if not hrp then continue end
        
        if AUTO_COLLECT_SHARDS then
            local shardsFolder = workspace:FindFirstChild("BloodmoonShards") or workspace:FindFirstChild("VoidShards")
            if shardsFolder then
                for _, shard in ipairs(shardsFolder:GetChildren()) do
                    if shard:IsA("BasePart") then
                        shard.CFrame = hrp.CFrame
                    end
                end
            end
        end
        
        if AUTO_COLLECT_RAIN then
            for _, obj in ipairs(workspace:GetChildren()) do
                if obj.Name == "RainDrop" and obj:IsA("BasePart") then
                    obj.CFrame = hrp.CFrame
                end
            end
        end
    end
end)

-- ========================================================================
-- 4. AUTO SKIP WAVE INSTANT
-- ========================================================================
task.spawn(function()
    while task.wait(1) do
        if not AUTO_SKIP_WAVE then continue end
        
        local waveRemotes = ReplicatedStorage:FindFirstChild("WaveRemotes")
        local skipVoteRemote = waveRemotes and waveRemotes:FindFirstChild("SkipVote")
            
        if skipVoteRemote then
            pcall(function()
                skipVoteRemote:FireServer(true)
            end)
        end
    end
end)

-- ========================================================================
-- 5. MOBILE & PC HUD CONTROL PANEL UI
-- ========================================================================
task.spawn(function()
    local parentGui = getGuiParent()
    if not parentGui then return end
    
    local oldGui = parentGui:FindFirstChild("AFK_Timer_Gui")
    if oldGui then oldGui:Destroy() end
    
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "AFK_Timer_Gui"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = parentGui
    
    local mainFrame = Instance.new("Frame")
    mainFrame.Name = "MainFrame"
    mainFrame.Size = UDim2.new(0, 240, 0, 115)
    mainFrame.Position = UDim2.new(0.5, -120, 0, 15)
    mainFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 26)
    mainFrame.BackgroundTransparency = 0.15
    mainFrame.BorderSizePixel = 0
    mainFrame.Active = true
    mainFrame.Parent = screenGui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = mainFrame
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(0, 230, 255)
    stroke.Thickness = 1.5
    stroke.Transparency = 0.3
    stroke.Parent = mainFrame
    
    -- Hỗ trợ Touch Drag mượt mà trên Mobile
    local dragging, dragInput, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    
    mainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    
    mainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)
    
    -- Tiêu đề
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, 0, 0, 20)
    titleLabel.Position = UDim2.new(0, 0, 0, 5)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.Text = "⚡ ZOMBIE AFK FARMING MOBILE"
    titleLabel.TextColor3 = Color3.fromRGB(0, 230, 255)
    titleLabel.TextSize = 12
    titleLabel.Parent = mainFrame
    
    -- Nhãn thời gian
    local timerLabel = Instance.new("TextLabel")
    timerLabel.Size = UDim2.new(1, 0, 0, 24)
    timerLabel.Position = UDim2.new(0, 0, 0, 25)
    timerLabel.BackgroundTransparency = 1
    timerLabel.Font = Enum.Font.GothamBlack
    timerLabel.Text = "⏱️ 00:00:00"
    timerLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    timerLabel.TextSize = 16
    timerLabel.Parent = mainFrame
    
    -- Nút Toggle Kill Aura
    local killBtn = Instance.new("TextButton")
    killBtn.Name = "KillBtn"
    killBtn.Size = UDim2.new(0, 105, 0, 28)
    killBtn.Position = UDim2.new(0, 10, 0, 55)
    killBtn.BackgroundColor3 = AUTO_KILL and Color3.fromRGB(30, 120, 60) or Color3.fromRGB(120, 30, 30)
    killBtn.Font = Enum.Font.GothamBold
    killBtn.Text = AUTO_KILL and "⚔️ KILL: ON" or "⚔️ KILL: OFF"
    killBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    killBtn.TextSize = 11
    killBtn.Parent = mainFrame
    
    local killCorner = Instance.new("UICorner")
    killCorner.CornerRadius = UDim.new(0, 6)
    killCorner.Parent = killBtn
    
    killBtn.MouseButton1Click:Connect(function()
        AUTO_KILL = not AUTO_KILL
        killBtn.Text = AUTO_KILL and "⚔️ KILL: ON" or "⚔️ KILL: OFF"
        killBtn.BackgroundColor3 = AUTO_KILL and Color3.fromRGB(30, 120, 60) or Color3.fromRGB(120, 30, 30)
    end)
    
    -- Nút Toggle Underground Safe
    local safeBtn = Instance.new("TextButton")
    safeBtn.Name = "SafeBtn"
    safeBtn.Size = UDim2.new(0, 105, 0, 28)
    safeBtn.Position = UDim2.new(0, 125, 0, 55)
    safeBtn.BackgroundColor3 = UNDERGROUND_SAFE and Color3.fromRGB(30, 120, 60) or Color3.fromRGB(120, 30, 30)
    safeBtn.Font = Enum.Font.GothamBold
    safeBtn.Text = UNDERGROUND_SAFE and "🛡️ SAFE: ON" or "🛡️ SAFE: OFF"
    safeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    safeBtn.TextSize = 11
    safeBtn.Parent = mainFrame
    
    local safeCorner = Instance.new("UICorner")
    safeCorner.CornerRadius = UDim.new(0, 6)
    safeCorner.Parent = safeBtn
    
    safeBtn.MouseButton1Click:Connect(function()
        UNDERGROUND_SAFE = not UNDERGROUND_SAFE
        safeBtn.Text = UNDERGROUND_SAFE and "🛡️ SAFE: ON" or "🛡️ SAFE: OFF"
        safeBtn.BackgroundColor3 = UNDERGROUND_SAFE and Color3.fromRGB(30, 120, 60) or Color3.fromRGB(120, 30, 30)
    end)
    
    local statusLabel = Instance.new("TextLabel")
    statusLabel.Size = UDim2.new(1, 0, 0, 18)
    statusLabel.Position = UDim2.new(0, 0, 0, 90)
    statusLabel.BackgroundTransparency = 1
    statusLabel.Font = Enum.Font.GothamMedium
    statusLabel.Text = "Status: Running Mobile-Safe..."
    statusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    statusLabel.TextSize = 10
    statusLabel.Parent = mainFrame
    
    local startTime = os.time()
    while task.wait(1) do
        local elapsed = os.time() - startTime
        local hours = math.floor(elapsed / 3600)
        local mins = math.floor((elapsed % 3600) / 60)
        local secs = elapsed % 60
        timerLabel.Text = string.format("⏱️ %02d:%02d:%02d", hours, mins, secs)
    end
end)

